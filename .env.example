OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=embeddinggemma

# Required. This must be the folder that contains your Obsidian vault notes.
# To find it: open your vault in Obsidian, reveal/open the vault folder in your
# file manager, then copy the vault folder's full path.
# Do not include a note filename; use the vault folder path only.
OBSIDIAN_VAULT_PATH=/Users/you/path/to/obsidian/vault

DATABASE_PATH=data/atlas.db
DEFAULT_TOP_K=5
